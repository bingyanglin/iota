{
	"ui": "tui",
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"lint": {},
		"lint:fix": {
			"dependsOn": ["^build"]
		},
		"prettier:fix": {
			"cache": false
		},
		"test": {
			"dependsOn": ["^build", "build"],
			"outputs": ["coverage/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true
		},
		"codegen": {
			"dependsOn": ["^codegen"],
			"cache": false,
			"persistent": false
		},
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["build/**", "dist/**", ".next/**", "!.next/cache/**"]
		}
	},
	"globalEnv": ["VERCEL_ENV", "BUILD_ENV"],
	"globalDependencies": ["prettier.config.js", ".prettierignore"]
}
