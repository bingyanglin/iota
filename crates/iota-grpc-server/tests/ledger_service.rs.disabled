        );
        assert!(
            status.message.contains("Invalid object_id"),
            "Error message should indicate invalid object_id"
        );
    } else {
        panic!("Expected error result for invalid object ID");
    }
}

// ============================================================================
// GetTransactions Tests
// ============================================================================

#[tokio::test(flavor = "multi_thread")]
async fn test_get_transactions_basic() {
    let (_cluster, mut client) = setup_test_cluster_and_client().await;

    // TODO: This test requires actual transaction data
    // For now, test with a fake digest to verify error handling
    let fake_digest = vec![0u8; 32];

    // Test GetTransactions with default mask (digest only)
    let request = GetTransactionsRequest {
        requests: Some(TransactionRequests {
            requests: vec![TransactionRequest {
                digest: Some(Digest {
                    digest: fake_digest,
                }),
            }],
        }),
        read_mask: None,
        max_message_size_bytes: None,
    };

    let mut stream = client
        .get_transactions(request)
        .await
        .expect("GetTransactions should succeed even if transaction not found")
        .into_inner();

    let response = stream
        .message()
        .await
        .expect("Should receive response")
        .expect("Response should not be None");

    assert_eq!(response.transactions.len(), 1, "Should return one result");

    let result = &response.transactions[0];
    // Should be an error result for non-existent transaction
    assert!(result.result.is_some(), "Result should contain error");
}

#[tokio::test(flavor = "multi_thread")]
async fn test_get_transactions_with_full_mask() {
    let (cluster, mut client) = setup_test_cluster_and_client().await;

    // Create a transaction by transferring coins
    let tx_digest = execute_transfer_transaction(&cluster).await;

    // Wait for the next checkpoint to ensure transaction is indexed
    tokio::time::sleep(tokio::time::Duration::from_secs(2)).await;

    // Request with full mask
    let request = GetTransactionsRequest {
        requests: Some(TransactionRequests {
            requests: vec![TransactionRequest {
                digest: Some(Digest {
                    digest: tx_digest.into_inner().to_vec(),
                }),
            }],
        }),
        read_mask: Some(FieldMask {
            paths: vec![
                "digest".to_string(),
                "transaction".to_string(),
                "signatures".to_string(),
                "effects".to_string(),
                "events".to_string(),
                "checkpoint".to_string(),
                "timestamp".to_string(),
            ],
        }),
        max_message_size_bytes: None,
    };

    let mut stream = client
        .get_transactions(request)
        .await
        .expect("GetTransactions should succeed")
        .into_inner();

    let response = stream
        .message()
        .await
        .expect("Should receive response")
        .expect("Response should not be None");

    assert_eq!(
        response.transactions.len(),
        1,
        "Should return one transaction"
    );

    let result = &response.transactions[0];
    if let Some(iota_grpc_types::v0::ledger_service::transaction_result::Result::Transaction(tx)) =
        &result.result
    {
        assert!(tx.digest.is_some(), "digest should be present");
        assert!(tx.transaction.is_some(), "transaction should be present");
        assert!(tx.signatures.is_some(), "signatures should be present");
        assert!(tx.effects.is_some(), "effects should be present");
        // events may or may not be present depending on transaction
        assert!(tx.checkpoint.is_some(), "checkpoint should be present");
        assert!(tx.timestamp.is_some(), "timestamp should be present");
    } else {
        panic!("Expected transaction result, got error");
    }
}

#[tokio::test(flavor = "multi_thread")]
async fn test_get_transactions_not_found() {
    let (_cluster, mut client) = setup_test_cluster_and_client().await;

    // Test with non-existent transaction digest
    let fake_digest = vec![0u8; 32]; // Invalid digest

    let request = GetTransactionsRequest {
        requests: Some(TransactionRequests {
            requests: vec![TransactionRequest {
                digest: Some(Digest {
                    digest: fake_digest,
                }),
            }],
        }),
        read_mask: None,
        max_message_size_bytes: None,
    };

    let mut stream = client
        .get_transactions(request)
        .await
        .expect("GetTransactions should succeed even if transaction not found")
        .into_inner();

    let response = stream
        .message()
        .await
        .expect("Should receive response")
        .expect("Response should not be None");

    assert_eq!(response.transactions.len(), 1, "Should return one result");

    let result = &response.transactions[0];
    // Should be an error result
    if let Some(iota_grpc_types::v0::ledger_service::transaction_result::Result::Error(status)) =
        &result.result
    {
        assert!(
            status.message.contains("not found") || status.message.contains("Not found"),
            "Error message should indicate transaction not found: {}",
            status.message
        );
    } else {
        panic!("Expected error result for non-existent transaction");
    }
}

#[tokio::test(flavor = "multi_thread")]
async fn test_get_transactions_with_bcs_mask() {
    let (cluster, mut client) = setup_test_cluster_and_client().await;

    // Create a transaction by transferring coins
    let tx_digest = execute_transfer_transaction(&cluster).await;

    // Wait for the next checkpoint to ensure transaction is indexed
    tokio::time::sleep(tokio::time::Duration::from_secs(2)).await;

    // Request with BCS fields only
    let request = GetTransactionsRequest {
        requests: Some(TransactionRequests {
            requests: vec![TransactionRequest {
                digest: Some(Digest {
                    digest: tx_digest.into_inner().to_vec(),
                }),
            }],
        }),
        read_mask: Some(FieldMask {
            paths: vec![
                "digest".to_string(),
                "transaction.bcs".to_string(),
                "signatures".to_string(),
                "effects.bcs".to_string(),
            ],
        }),
        max_message_size_bytes: None,
    };

    let mut stream = client
        .get_transactions(request)
        .await
        .expect("GetTransactions should succeed")
        .into_inner();

    let response = stream
        .message()
        .await
        .expect("Should receive response")
        .expect("Response should not be None");

    assert_eq!(
        response.transactions.len(),
        1,
        "Should return one transaction"
    );

    let result = &response.transactions[0];
    if let Some(iota_grpc_types::v0::ledger_service::transaction_result::Result::Transaction(tx)) =
        &result.result
    {
        assert!(tx.digest.is_some(), "digest should be present");
        assert!(tx.transaction.is_some(), "transaction should be present");

        let transaction = tx.transaction.as_ref().unwrap();
        assert!(
            transaction.bcs.is_some(),
            "transaction.bcs should be present"
        );
        assert!(
            !transaction.bcs.as_ref().unwrap().data.is_empty(),
            "transaction.bcs data should not be empty"
        );

        assert!(tx.signatures.is_some(), "signatures should be present");
        assert!(tx.effects.is_some(), "effects should be present");

        let effects = tx.effects.as_ref().unwrap();
        assert!(effects.bcs.is_some(), "effects.bcs should be present");
        assert!(
            !effects.bcs.as_ref().unwrap().data.is_empty(),
            "effects.bcs data should not be empty"
        );
    } else {
        panic!("Expected transaction result, got error");
    }
}

/// Helper function to execute a simple transfer transaction
async fn execute_transfer_transaction(
    cluster: &TestCluster,
) -> iota_types::digests::TransactionDigest {
    use iota_types::crypto::{AccountKeyPair, KeypairTraits, get_key_pair};

    // Get the wallet context
    let context = &cluster.wallet;

    // Get gas price and accounts
    let gas_price = context.get_reference_gas_price().await.unwrap();
    let accounts_and_objs = context.get_all_accounts_and_gas_objects().await.unwrap();

    let sender = accounts_and_objs[0].0;
    let gas_object = accounts_and_objs[0].1[0];

    // Get a recipient address (use a different account or generate new one)
    let (_recipient_addr, recipient_key): (_, AccountKeyPair) = get_key_pair();
    let recipient = recipient_key.public().into();

    // Build transfer transaction
    let txn = context.sign_transaction(
        &iota_test_transaction_builder::TestTransactionBuilder::new(sender, gas_object, gas_price)
            .transfer_iota(Some(1000), recipient)
            .build(),
    );

    // Execute transaction
    let resp = context.execute_transaction_must_succeed(txn).await;
    resp.digest
}
