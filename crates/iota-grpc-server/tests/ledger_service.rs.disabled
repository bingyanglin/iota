#[tokio::test(flavor = "multi_thread")]
async fn test_get_objects_not_found() {
    let (_cluster, mut client) = setup_test_cluster_and_client().await;

    // Test GetObjects with non-existent object
    let request = GetObjectsRequest {
        requests: Some(ObjectRequests {
            requests: vec![ObjectRequest {
                object_ref: Some(ObjectReference {
                    object_id: Some(
                        "0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef"
                            .to_string(),
                    ),
                    version: None,
                    digest: None,
                }),
            }],
        }),
        read_mask: None,
        max_message_size_bytes: None,
    };

    let mut stream = client
        .get_objects(request)
        .await
        .expect("GetObjects should succeed even if object not found")
        .into_inner();

    let response = stream
        .message()
        .await
        .expect("Should receive response")
        .expect("Response should not be None");

    assert_eq!(response.objects.len(), 1, "Should return one result");

    let result = &response.objects[0];
    // Should be an error result
    if let Some(iota_grpc_types::v0::ledger_service::object_result::Result::Error(status)) =
        &result.result
    {
        assert_eq!(
            status.code,
            tonic::Code::NotFound as i32,
            "Error should be NotFound"
        );
        assert!(
            status.message.contains("not found"),
            "Error message should indicate object not found"
        );
    } else {
        panic!("Expected error result for non-existent object");
    }
}

