#[tokio::test(flavor = "multi_thread")]
async fn test_get_service_info_default() {
    let (_cluster, mut client) = setup_test_cluster_and_client().await;

    // Test GetServiceInfo with default mask
    let request = GetServiceInfoRequest { read_mask: None };

    let response = client
        .get_service_info(request)
        .await
        .expect("GetServiceInfo should succeed");

    let response = response.into_inner();

    // Default mask includes: chain_id, epoch, executed_checkpoint_height
    assert!(response.chain_id.is_some(), "chain_id should be present");
    assert!(response.epoch.is_some(), "epoch should be present");
    assert!(
        response.executed_checkpoint_height.is_some(),
        "executed_checkpoint_height should be present"
    );

    // Verify chain_id is present and is a valid hex string
    let chain_id = response.chain_id.unwrap();
    assert!(chain_id.starts_with("0x"), "chain_id should start with 0x");
    // Chain ID format can vary, just verify it's a valid hex string
    assert!(
        chain_id.len() >= 3,
        "chain_id should be at least 0x + 1 hex char"
    );
}

#[tokio::test(flavor = "multi_thread")]
async fn test_get_service_info_all_fields() {
    let (_cluster, mut client) = setup_test_cluster_and_client().await;

    // Test with field mask requesting all fields
    let request = GetServiceInfoRequest {
        read_mask: Some(FieldMask {
            paths: vec![
                "chain_id".to_string(),
                "chain".to_string(),
                "epoch".to_string(),
                "executed_checkpoint_height".to_string(),
                "executed_checkpoint_timestamp".to_string(),
                "lowest_available_checkpoint".to_string(),
                "lowest_available_checkpoint_objects".to_string(),
                "server".to_string(),
            ],
        }),
    };

    let response = client
        .get_service_info(request)
        .await
        .expect("GetServiceInfo with all fields should succeed");

    let response = response.into_inner();

    assert!(response.chain_id.is_some(), "chain_id should be present");
    assert!(response.chain.is_some(), "chain should be present");
    assert!(response.epoch.is_some(), "epoch should be present");
    assert!(
        response.executed_checkpoint_height.is_some(),
        "executed_checkpoint_height should be present"
    );
    assert!(
        response.executed_checkpoint_timestamp.is_some(),
        "executed_checkpoint_timestamp should be present"
    );
    assert!(
        response.lowest_available_checkpoint.is_some(),
        "lowest_available_checkpoint should be present"
    );
    assert!(
        response.lowest_available_checkpoint_objects.is_some(),
        "lowest_available_checkpoint_objects should be present"
    );
    assert!(response.server.is_some(), "server should be present");

    // Verify timestamp structure
    let timestamp = response.executed_checkpoint_timestamp.unwrap();
    assert!(timestamp.seconds >= 0, "timestamp seconds should be valid");
}

